PORT=5000
NODE_ENV=production

# Railway MySQL — copy the "MySQL URL" from your Railway service dashboard
DATABASE_URL=mysql://user:password@host.railway.app:PORT/railway

# Supabase — from your Supabase project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vercel frontend URL (update after deploying frontend)
CLIENT_URL=https://your-app.vercel.app

# Notchpay
NOTCHPAY_PUBLIC_KEY=pk_live.your_key
NOTCHPAY_SECRET_HASH=your_secret_hash

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your@gmail.com
FROM_NAME=HouseTrack
